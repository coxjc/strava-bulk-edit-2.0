{
  "manifest_version": 3,
  "name": "Strava Bulk Edit 2.0",
  "description": "Bulk edit privacy, gear, ride type, and more across all your Strava activities at once — with optional date range filtering.",
  "author": "Colby Cox <uoflcards22@gmail.com>",
  "homepage_url": "https://github.com/coxjc/strava-bulk-edit-2.0",
  "version": "2.0.0",
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "icons": {
    "16": "images/strava-bulk-edit-logo-16.png",
    "32": "images/strava-bulk-edit-logo-32.png",
    "48": "images/strava-bulk-edit-logo-48.png",
    "128": "images/strava-bulk-edit-logo-128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://www.strava.com/athlete/training"],
      "css": ["updateActivities.css"],
      "js": ["updateActivities.js"]
    }
  ],
  "host_permissions": [
    "https://www.strava.com/"
  ],
  "action": {
    "default_title": "Strava Bulk Edit",
    "default_icon": {
      "16": "images/strava-bulk-edit-logo-16.png",
      "32": "images/strava-bulk-edit-logo-32.png",
      "48": "images/strava-bulk-edit-logo-48.png",
      "128": "images/strava-bulk-edit-logo-128.png"
    }
  }
}
